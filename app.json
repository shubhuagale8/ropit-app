{
  "expo": {
    "name": "Ropit",
    "slug": "ropit",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ropit.nursery",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "googleMapsApiKey": "AIzaSyCvBBtmxOUM-hWWI50O8CGISQRX7lxe73M"
      }
    },
    "android": {
      "package": "com.ropit.nursery",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCvBBtmxOUM-hWWI50O8CGISQRX7lxe73M"
        }
      }
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Ropit needs your location to help farmers find your nursery."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0",
            "kotlinVersion": "1.9.24"
          }
        }
      ]
    ]
  }
}
